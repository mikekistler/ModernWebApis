{
  "openapi": "3.1.1",
  "info": {
    "title": "Demo.Catalog | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/catalog/items": {
      "get": {
        "tags": [
          "CatalogApi"
        ],
        "summary": "List catalog items",
        "description": "Get a paginated list of items in the catalog.",
        "operationId": "ListItems",
        "parameters": [
          {
            "name": "PageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "PageIndex",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "name",
            "in": "query",
            "description": "The name of the item to return",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "The type of items to return",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "brand",
            "in": "query",
            "description": "The brand of items to return",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedItemsOfCatalogItem"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "CatalogApi"
        ],
        "summary": "Create a catalog item",
        "description": "Create a new item in the catalog",
        "operationId": "CreateItem",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CatalogItem"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/catalog/items/by": {
      "get": {
        "tags": [
          "CatalogApi"
        ],
        "summary": "Batch get catalog items",
        "description": "Get multiple items from the catalog",
        "operationId": "BatchGetItems",
        "parameters": [
          {
            "name": "ids",
            "in": "query",
            "description": "List of ids for catalog items to return",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer",
                "format": "int32"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CatalogItem"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/catalog/items/{id}": {
      "get": {
        "tags": [
          "CatalogApi"
        ],
        "summary": "Get catalog item",
        "description": "Get an item from the catalog",
        "operationId": "GetItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The catalog item id",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogItem"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "CatalogApi"
        ],
        "summary": "Create or replace a catalog item",
        "description": "Create or replace a catalog item",
        "operationId": "UpdateItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The catalog item id",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CatalogItem"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "CatalogApi"
        ],
        "summary": "Delete catalog item",
        "description": "Delete the specified catalog item",
        "operationId": "DeleteItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The catalog item id",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/catalog/items/{id}/pic": {
      "get": {
        "tags": [
          "CatalogApi"
        ],
        "summary": "Get catalog item picture",
        "description": "Get the picture for a catalog item",
        "operationId": "GetItemPicture",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The catalog item id",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "404": {
            "description": "Not Found"
          },
          "200": {
            "description": "OK",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "byte"
                }
              },
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "byte"
                }
              },
              "image/gif": {
                "schema": {
                  "type": "string",
                  "format": "byte"
                }
              },
              "image/jpeg": {
                "schema": {
                  "type": "string",
                  "format": "byte"
                }
              },
              "image/bmp": {
                "schema": {
                  "type": "string",
                  "format": "byte"
                }
              },
              "image/tiff": {
                "schema": {
                  "type": "string",
                  "format": "byte"
                }
              },
              "image/wmf": {
                "schema": {
                  "type": "string",
                  "format": "byte"
                }
              },
              "image/jp2": {
                "schema": {
                  "type": "string",
                  "format": "byte"
                }
              },
              "image/svg+xml": {
                "schema": {
                  "type": "string",
                  "format": "byte"
                }
              },
              "image/webp": {
                "schema": {
                  "type": "string",
                  "format": "byte"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CatalogItem": {
        "required": [
          "name",
          "description",
          "price",
          "catalogType",
          "catalogBrand"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the catalog item.",
            "format": "int32"
          },
          "name": {
            "maxLength": 50,
            "minLength": 3,
            "type": [
              "null",
              "string"
            ],
            "description": "Name of the product."
          },
          "description": {
            "maxLength": 500,
            "minLength": 10,
            "type": [
              "null",
              "string"
            ],
            "description": "Detailed description of the product."
          },
          "price": {
            "maximum": 10000,
            "minimum": 0.01,
            "type": "number",
            "description": "Current price of the product.",
            "format": "double"
          },
          "pictureFileName": {
            "type": [
              "null",
              "string"
            ],
            "description": "Filename of the product image."
          },
          "catalogType": {
            "maxLength": 100,
            "type": [
              "null",
              "string"
            ],
            "description": "Category or type of the product."
          },
          "catalogBrand": {
            "maxLength": 100,
            "type": [
              "null",
              "string"
            ],
            "description": "Brand of the product."
          },
          "availableStock": {
            "type": "integer",
            "description": "Current quantity available in stock.",
            "format": "int32"
          },
          "restockThreshold": {
            "type": "integer",
            "description": "Available stock at which we should reorder.",
            "format": "int32"
          },
          "maxStockThreshold": {
            "type": "integer",
            "description": "Maximum number of units that can be in-stock at any time (due to physical/logistical constraints in warehouses).",
            "format": "int32"
          },
          "onReorder": {
            "type": "boolean",
            "description": "Indicates whether the item is currently in the process of being restocked."
          }
        },
        "description": "Represents an item in the catalog with detailed product information."
      },
      "PaginatedItemsOfCatalogItem": {
        "required": [
          "pageIndex",
          "pageSize",
          "count",
          "data"
        ],
        "type": "object",
        "properties": {
          "pageIndex": {
            "type": "integer",
            "description": "The zero-based index of current page.",
            "format": "int32"
          },
          "pageSize": {
            "type": "integer",
            "description": "Number of items per page",
            "format": "int32"
          },
          "count": {
            "type": "integer",
            "description": "Total number of items across all pages",
            "format": "int64"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CatalogItem"
            },
            "description": "Collection of items for the current page"
          }
        },
        "description": "Represents a paginated collection of items for use in API responses."
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "type": [
              "null",
              "integer"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "CatalogApi"
    }
  ]
}