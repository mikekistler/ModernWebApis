content-type: application/json

{
  "name": "Test Item",
  "description": "This is a test description that is long enough",
  "price": 199.99,
  "catalogType": "This catalog type is way too long and should exceed the 100 character limit specified in the API schema for this field",
  "catalogBrand": "Test Brand",
  "availableStock": 10
}

###
# Test - CatalogBrand too long (> 100 characters)
POST {{HostAddress}}/catalog/items
content-type: application/json

{
  "name": "Test Item",
  "description": "This is a test description that is long enough",
  "price": 199.99,
