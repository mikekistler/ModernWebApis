###
# Test - Successful create request with all valid required fields
POST {{HostAddress}}/catalog/items
content-type: application/json

{
  "name": "Test Valid Item",
  "description": "This is a valid test description for a catalog item",
  "price": 299.99,
  "catalogType": "Valid Type",
  "catalogBrand": "Valid Brand",
  "availableStock": 100,
  "restockThreshold": 10,
  "maxStockThreshold": 200,
  "onReorder": false
}

###
# Test - PUT update with mismatched ID
PUT {{HostAddress}}/catalog/items/999
content-type: application/json

{
  "id": 1,
  "name": "Updated Item",
  "description": "This is an updated description",
  "price": 399.99,
  "catalogType": "Updated Type",
  "catalogBrand": "Updated Brand",
  "availableStock": 50
}

###
# Test - PUT with valid data
PUT {{HostAddress}}/catalog/items/1
content-type: application/json

{
  "id": 1,
  "name": "Updated Item",
  "description": "This is an updated description for the existing item",
  "price": 399.99,
  "catalogType": "Updated Type",
  "catalogBrand": "Updated Brand",
  "availableStock": 50
}

