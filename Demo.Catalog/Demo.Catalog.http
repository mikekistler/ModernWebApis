@HostAddress = https://localhost:7516

GET {{HostAddress}}/health

###

GET {{HostAddress}}/openapi/v1.json
Accept: application/json

###

GET {{HostAddress}}/catalog/items
Accept: application/json

###

@itemId = 1

GET {{HostAddress}}/catalog/items/{{itemId}}
Accept: application/json

###

GET {{HostAddress}}/catalog/items/{{itemId}}/pic
Accept: image/jpeg

###

GET {{HostAddress}}/catalog/items?type=Footwear

###

# A request with an unknown item id returns a 404 NotFound with ProblemDetails response

GET {{HostAddress}}/catalog/items/463

###

# Invalid - name is missing

POST {{HostAddress}}/catalog/items
content-type: application/json

{
  "id": 421,
  "price": 100,
  "description": "Description1",
  "pictureFileName": "item421.png",
  "catalogTypeId": 1,
  "catalogBrandId": 2
}

###
# Test - Invalid price (below minimum)
POST {{HostAddress}}/catalog/items
content-type: application/json

{
  "name": "Test Item",
  "description": "This is a test description that is long enough",
  "price": 0,
  "catalogType": "Test Type",
  "catalogBrand": "Test Brand",
  "availableStock": 10
}

###
# Test - Invalid price (above maximum)
POST {{HostAddress}}/catalog/items
content-type: application/json

{
  "name": "Test Item",
  "description": "This is a test description that is long enough",
  "price": 20000,
  "catalogType": "Test Type",
  "catalogBrand": "Test Brand",
  "availableStock": 10
}

###
# Test - Name too short (< 3 characters)
POST {{HostAddress}}/catalog/items
content-type: application/json

{
  "name": "AB",
  "description": "This is a test description that is long enough",
  "price": 199.99,
  "catalogType": "Test Type",
  "catalogBrand": "Test Brand",
  "availableStock": 10
}

###
# Test - Name too long (> 50 characters)
POST {{HostAddress}}/catalog/items
content-type: application/json

{
  "name": "This name is way too long for the catalog item and should trigger a validation error because it exceeds fifty characters",
  "description": "This is a test description that is long enough",
  "price": 199.99,
  "catalogType": "Test Type",
  "catalogBrand": "Test Brand",
  "availableStock": 10
}

###
# Test - Description too short (< 10 characters)
POST {{HostAddress}}/catalog/items
content-type: application/json

