content-type: application/json

{
  "name": "Test Item",
  "description": "This description is way too long and should exceed the 500 character limit specified in the API schema. It's going to be filled with a bunch of repetitive text just to make it go over the limit. This description is way too long and should exceed the 500 character limit specified in the API schema. It's going to be filled with a bunch of repetitive text just to make it go over the limit. This description is way too long and should exceed the 500 character limit specified in the API schema. It's going to be filled with a bunch of repetitive text just to make it go over the limit. This description is way too long and should exceed the 500 character limit specified in the API schema. It's going to be filled with a bunch of repetitive text just to make it go over the limit.",
  "price": 199.99,
  "catalogType": "Test Type",
  "catalogBrand": "Test Brand",
  "availableStock": 10
}

